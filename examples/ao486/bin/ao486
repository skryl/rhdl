#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'

$LOAD_PATH.unshift File.expand_path('../../../lib', __dir__)

require 'rhdl'
require_relative '../utilities/tasks/run_task'

module RHDL
  module Examples
    module AO486
      module CLI
        module_function

        def default_options
          {
            debug: false,
            headless: false,
            max_steps: 1_000_000,
            load_addr: 0x0100,
            com: false,
            help: false
          }
        end

        def parse_u32(value)
          Integer(value, 0) & 0xFFFF_FFFF
        rescue ArgumentError
          raise OptionParser::InvalidArgument, value
        end

        def build_parser(options, out:)
          OptionParser.new do |opts|
            opts.banner = "Usage: bin/ao486 [options] <program.com|program.bin>"
            opts.separator ""
            opts.separator "ao486 CPU Runner — execute x86 binaries in the RHDL ao486 simulator"
            opts.separator ""

            opts.on("--com", "Load as DOS .COM at CS:0100h (default for .com files)") do
              options[:com] = true
            end

            opts.on("-a", "--address ADDR", "Load address (hex/dec, default: 0x0100)") do |v|
              options[:load_addr] = parse_u32(v)
            end

            opts.on("-s", "--steps N", Integer, "Maximum execution steps (default: 1000000)") do |v|
              options[:max_steps] = v
            end

            opts.on("-d", "--debug", "Show CPU state after execution") do
              options[:debug] = true
            end

            opts.on("--headless", "Run without interactive terminal") do
              options[:headless] = true
            end

            opts.on("-h", "--help", "Show help") do
              out.puts opts
              options[:help] = true
            end
          end
        end

        def run(argv = ARGV, out: $stdout)
          args = argv.dup
          options = default_options
          parser = build_parser(options, out: out)

          begin
            parser.parse!(args)
          rescue OptionParser::ParseError => e
            out.puts "Error: #{e.message}"
            out.puts parser
            return 1
          end

          return 0 if options[:help]

          program_file = args.shift
          unless program_file
            out.puts parser
            out.puts ''
            out.puts 'Error: No program specified.'
            return 1
          end

          unless File.file?(program_file)
            out.puts "Error: Program file not found: #{program_file}"
            return 1
          end

          # Auto-detect .COM files
          is_com = options[:com] || program_file.downcase.end_with?('.com')

          begin
            task = Tasks::RunTask.new(options)

            if is_com
              task.load_com(program_file)
            else
              task.load_binary(program_file, addr: options[:load_addr])
            end

            task.run
            0
          rescue Interrupt
            out.puts "\nInterrupted."
            0
          rescue StandardError => e
            out.puts "Error: #{e.message}"
            out.puts e.backtrace.first(5).join("\n") if options[:debug]
            1
          end
        end
      end
    end
  end
end

exit(RHDL::Examples::AO486::CLI.run(ARGV)) if __FILE__ == $PROGRAM_NAME
