 void __delay(unsigned long cycles)
 {
+	/*
+	 * Local RHDL simulation optimization:
+	 * Cap long busy-wait loops to keep Linux boot practical under
+	 * cycle-accurate simulation.
+	 */
+	if (cycles > 64)
+		cycles = 64;
+
 	u64 t0 = get_cycles();
 
+	if (!cycles)
+		return;
+
 	while ((unsigned long)(get_cycles() - t0) < cycles)
